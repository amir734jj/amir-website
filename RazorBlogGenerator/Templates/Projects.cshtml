@inherits RazorLight.TemplatePage<RenderContext>
@using RazorBlogGenerator.Models
@model RenderContext
@{
    var projects = (ProjectsModel)Model.Page;
}

<h2 class="mb-4">@Model.Page.Title</h2>

@if (!string.IsNullOrEmpty(projects.Description))
{
  <p class="lead text-secondary mb-5">@Raw(projects.Description.Replace(Environment.NewLine, "<br />"))</p>
}

@if (projects.Projects.Count == 0)
{
  <p class="text-muted">No projects yet.</p>
}
else
{
  <div class="row row-cols-1 row-cols-md-2 g-4">
    @foreach (var project in projects.Projects)
    {
      <div class="col">
        <div class="card h-100">
          @if (!string.IsNullOrWhiteSpace(project.Image))
          {
            <img src="@project.Image" class="card-img-top" alt="@project.Name" style="object-fit: cover; height: 200px;" />
          }
          <div class="card-body d-flex flex-column">
            <h5 class="card-title">@project.Name</h5>
            <p class="card-text text-secondary flex-grow-1">@project.Description</p>
            <div class="d-flex gap-2 mt-2">
              @if (!string.IsNullOrWhiteSpace(project.GithubUrl))
              {
                <a href="@project.GithubUrl" target="_blank" rel="noopener" class="btn btn-outline-dark btn-sm">
                  <i class="bi bi-github"></i> GitHub
                </a>
              }
              @if (!string.IsNullOrWhiteSpace(project.WebsiteUrl))
              {
                <a href="@project.WebsiteUrl" target="_blank" rel="noopener" class="btn btn-outline-primary btn-sm">
                  <i class="bi bi-globe"></i> Website
                </a>
              }
            </div>
          </div>
        </div>
      </div>
    }
  </div>
}

@if (projects.Libraries.Count > 0)
{
  <h3 class="mt-5 mb-3">Libraries</h3>
  <ul class="list-group list-group-flush">
    @foreach (var lib in projects.Libraries)
    {
      <li class="list-group-item d-flex justify-content-between align-items-start">
        <div>
          <strong>@lib.Name</strong>
          <p class="text-secondary mb-0 small">@lib.Description</p>
        </div>
        <a href="@lib.GithubUrl" target="_blank" rel="noopener" class="btn btn-outline-dark btn-sm ms-3 flex-shrink-0">
          <i class="bi bi-github"></i> GitHub
        </a>
      </li>
    }
  </ul>
}
