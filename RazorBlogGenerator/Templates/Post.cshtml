@inherits RazorLight.TemplatePage<RenderContext>
@using RazorBlogGenerator.Models
@model RenderContext
@{
    var post = (PostModel)Model.Page;
}

<article>
  <p class="text-muted small">@post.PublishedOn</p>
  <h2 class="display-6 fw-bold">@post.Title</h2>
  <p class="lead text-secondary">@post.Excerpt</p>
  @if (post.Tags.Count > 0)
  {
    <div class="mb-3">
      @foreach (var tag in post.Tags)
      {
        <span class="badge bg-secondary me-1">@tag</span>
      }
    </div>
  }
  <hr />
  <div>@Raw(post.RenderedHtml)</div>
</article>
