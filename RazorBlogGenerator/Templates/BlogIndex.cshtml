@inherits RazorLight.TemplatePage<TModel>
@using RazorBlogGenerator.Models
@model RenderContext
@{
    var posts = Model.AllPages.OfType<PostModel>().OrderByDescending(p => p.PublishedOn).ToList();
}

<h1 class="mb-4">Blog</h1>

@if (posts.Count == 0)
{
  <p class="text-muted">No posts yet.</p>
}
else
{
  @foreach (var post in posts)
  {
    <div class="card mb-3">
      <div class="card-body">
        <p class="text-muted small mb-1">@post.PublishedOn</p>
        <h2 class="h5"><a href="/@post.Slug" class="text-decoration-none">@post.Title</a></h2>
        <p class="card-text text-secondary">@post.Excerpt</p>
      </div>
    </div>
  }
}
